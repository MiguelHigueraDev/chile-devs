# Backend server URL (optional).
# When unset, API requests use the relative /api path and the dev server proxies to http://localhost:3000.
VITE_BACKEND_URL=http://localhost:3000

# Public site URL used for Open Graph, canonical links, robots.txt, and sitemap.xml.
# Set this to your production frontend origin when deploying.
VITE_SITE_URL=http://localhost:5173
